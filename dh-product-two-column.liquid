{% comment %} ── SNIPPET: snippets/dh-two-col-block.liquid ──
Paste this into a new file: snippets/dh-two-col-block.liquid

{%- case block.type -%}

  {%- when 'rich_text' -%}
    <div class="dh-block-richtext" {{ block.shopify_attributes }}>
      {%- if block.settings.heading != blank -%}
        <h2 class="dh-block-richtext__heading">{{ block.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if block.settings.body != blank -%}
        <div class="dh-block-richtext__body rte">{{ block.settings.body }}</div>
      {%- endif -%}
    </div>

  {%- when 'custom_liquid' -%}
    <div class="dh-block-custom-liquid" {{ block.shopify_attributes }}>
      {{ block.settings.custom_liquid }}
    </div>

  {%- when 'image' -%}
    <div class="dh-block-image" {{ block.shopify_attributes }}>
      {%- if block.settings.heading != blank -%}
        <h3 class="dh-block-image__heading">{{ block.settings.heading | escape }}</h3>
      {%- endif -%}
      {%- if block.settings.image != blank -%}
        {%- assign img_width = block.settings.image_width | default: 100 -%}
        <span class="dh-block-image__img-wrap" style="max-width: {{ img_width }}%;">
          {{
            block.settings.image
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              widths: '400, 600, 800, 1000, 1200',
              sizes: '(max-width: 749px) 100vw, 50vw'
          }}
        </span>
      {%- endif -%}
      {%- if block.settings.text != blank -%}
        <div class="dh-block-image__text rte">{{ block.settings.text }}</div>
      {%- endif -%}
    </div>

{%- endcase -%}
{% endcomment %}

{% comment %} ──────────────────────────────────────────────────────────────
  END SNIPPET REFERENCE
  The inline block rendering below is used when the snippet is not present.
  It duplicates the snippet logic so this section works standalone.
────────────────────────────────────────────────────────────────────────── {% endcomment %}

{%- comment -%}
  Shopify does not allow liquid inside HTML comments without rendering it,
  so the full inline block rendering is embedded directly in the column loops
  using the render tag pointing to the snippet above.

  If you prefer a single-file setup with no snippet dependency,
  replace the two `for block in section.blocks` loops with the version below:

  LEFT COLUMN LOOP (replace the left col div contents):

  {%- for block in section.blocks -%}
    {%- if block.settings.column == 'left' or block.settings.column == blank -%}
      {%- case block.type -%}
        {%- when 'rich_text' -%}
          <div class="dh-block-richtext" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h2 class="dh-block-richtext__heading">{{ block.settings.heading | escape }}</h2>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <div class="dh-block-richtext__body rte">{{ block.settings.body }}</div>
            {%- endif -%}
          </div>
        {%- when 'custom_liquid' -%}
          <div class="dh-block-custom-liquid" {{ block.shopify_attributes }}>
            {{ block.settings.custom_liquid }}
          </div>
        {%- when 'image' -%}
          <div class="dh-block-image" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h3 class="dh-block-image__heading">{{ block.settings.heading | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.image != blank -%}
              {%- assign img_width = block.settings.image_width | default: 100 -%}
              <span class="dh-block-image__img-wrap" style="max-width: {{ img_width }}%;">
                {{
                  block.settings.image
                  | image_url: width: 1200
                  | image_tag:
                    loading: 'lazy',
                    widths: '400, 600, 800, 1000, 1200',
                    sizes: '(max-width: 749px) 100vw, 50vw'
                }}
              </span>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <div class="dh-block-image__text rte">{{ block.settings.text }}</div>
            {%- endif -%}
          </div>
      {%- endcase -%}
    {%- endif -%}
  {%- endfor -%}

  (Mirror the same case block for the right column loop, swapping the column check to == 'right')
{%- endcomment -%}

{% schema %}
{
  "name": "DH Two Column",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "column_ratio",
      "label": "Column width ratio",
      "options": [
        { "value": "50-50", "label": "50 / 50" },
        { "value": "60-40", "label": "60 / 40" },
        { "value": "40-60", "label": "40 / 60" },
        { "value": "66-33", "label": "66 / 33" },
        { "value": "33-66", "label": "33 / 66" }
      ],
      "default": "50-50"
    },
    {
      "type": "select",
      "id": "vertical_align",
      "label": "Vertical alignment",
      "options": [
        { "value": "start",  "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "end",    "label": "Bottom" }
      ],
      "default": "start"
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Gap between columns",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "inverse",      "label": "Inverse" },
        { "value": "accent-1",     "label": "Accent 1" },
        { "value": "accent-2",     "label": "Accent 2" }
      ],
      "default": "background-1",
      "info": "Inherits Enterprise theme color scheme tokens."
    }
  ],
  "blocks": [
    {
      "type": "rich_text",
      "name": "Rich text",
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Column",
          "options": [
            { "value": "left",  "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Section heading"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body",
          "default": "<p>Use this block to add rich text content to either column. Supports <strong>bold</strong>, <em>italic</em>, links, and lists.</p>"
        }
      ]
    },
    {
      "type": "custom_liquid",
      "name": "Custom liquid",
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Column",
          "options": [
            { "value": "left",  "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "right"
        },
        {
          "type": "liquid",
          "id": "custom_liquid",
          "label": "Custom liquid",
          "info": "Add custom Liquid code. Access product, variant, and other Shopify objects here."
        }
      ]
    },
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Column",
          "options": [
            { "value": "left",  "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "range",
          "id": "image_width",
          "label": "Image width",
          "min": 20,
          "max": 100,
          "step": 5,
          "unit": "%",
          "default": 100,
          "info": "Percentage of the column width."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading (optional)"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DH Two Column",
      "blocks": [
        {
          "type": "rich_text",
          "settings": {
            "column": "left",
            "heading": "Left column heading",
            "body": "<p>Add your left column content here.</p>"
          }
        },
        {
          "type": "rich_text",
          "settings": {
            "column": "right",
            "heading": "Right column heading",
            "body": "<p>Add your right column content here.</p>"
          }
        }
      ]
    }
  ],
  "templates": ["product", "page", "index"]
}
{% endschema %}
