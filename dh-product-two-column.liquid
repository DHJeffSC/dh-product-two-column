{% comment %}
  DH Product Two Column Section
  A flexible two-column layout section for Shopify OS 2.0 product pages.
  Block types: heading, rich text, custom liquid, image, gallery.
  Each block can be assigned to left column, right column, or both (full-width span).
{% endcomment %}

{%- liquid
  assign section_id    = 'dh-two-col-' | append: section.id
  assign col_ratio     = section.settings.column_ratio     | default: '50-50'
  assign col_gap       = section.settings.column_gap       | default: 32
  assign pt            = section.settings.padding_top      | default: 40
  assign pb            = section.settings.padding_bottom   | default: 40
  assign v_align       = section.settings.vertical_align   | default: 'start'
  assign bg_color      = section.settings.background_color
  assign max_width_key = section.settings.max_width        | default: 'page'
  assign content_align = section.settings.content_alignment | default: 'center'

  case max_width_key
    when 'narrow'
      assign max_width_val = '720px'
    when 'medium'
      assign max_width_val = '960px'
    when 'wide'
      assign max_width_val = '1200px'
    when 'full'
      assign max_width_val = '100%'
    else
      assign max_width_val = 'var(--page-width, 1200px)'
  endcase

  case content_align
    when 'left'
      assign container_margin = '0 auto 0 0'
    when 'right'
      assign container_margin = '0 0 0 auto'
    else
      assign container_margin = '0 auto'
  endcase

  case col_ratio
    when '50-50'
      assign left_fr  = '1fr'
      assign right_fr = '1fr'
    when '60-40'
      assign left_fr  = '3fr'
      assign right_fr = '2fr'
    when '40-60'
      assign left_fr  = '2fr'
      assign right_fr = '3fr'
    when '66-33'
      assign left_fr  = '2fr'
      assign right_fr = '1fr'
    when '33-66'
      assign left_fr  = '1fr'
      assign right_fr = '2fr'
    else
      assign left_fr  = '1fr'
      assign right_fr = '1fr'
  endcase

  assign has_col_blocks = false
  for block in section.blocks
    if block.settings.column == 'left' or block.settings.column == 'right' or block.settings.column == blank
      assign has_col_blocks = true
    endif
  endfor
-%}

<style>
  /* ── Section wrapper ── */
  #{{ section_id }} {
    background-color: {{ bg_color }};
    padding-top: {{ pt }}px;
    padding-bottom: {{ pb }}px;
  }

  /* ── Page-width container ── */
  #{{ section_id }} .dh-two-col__container {
    max-width: {{ max_width_val }};
    margin: {{ container_margin }};
    padding-inline: var(--page-width-margin, clamp(1.5rem, 5vw, 3rem));
    box-sizing: border-box;
  }

  /* ── Inner wrapper: stacks spanning rows + the grid with a consistent gap ── */
  #{{ section_id }} .dh-two-col__inner {
    display: flex;
    flex-direction: column;
    gap: {{ col_gap }}px;
  }

  /* ── Two-column grid ── */
  #{{ section_id }} .dh-two-col__grid {
    display: grid;
    grid-template-columns: {{ left_fr }} {{ right_fr }};
    gap: {{ col_gap }}px;
    align-items: {{ v_align }};
  }

  /* ── Column wrappers ── */
  #{{ section_id }} .dh-two-col__col {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    min-width: 0;
  }

  /* ── Spanning block row (full width) ── */
  #{{ section_id }} .dh-two-col__span {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
  }

  /* ────────────────────────────────────────────────
     HEADING BLOCK
  ─────────────────────────────────────────────── */
  #{{ section_id }} .dh-block-heading {
    margin: 0;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-foreground, inherit);
  }

  /* ────────────────────────────────────────────────
     RICH TEXT BLOCK
  ─────────────────────────────────────────────── */
  #{{ section_id }} .dh-block-richtext__heading {
    margin: 0 0 0.5rem;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-foreground, inherit);
  }

  #{{ section_id }} .dh-block-richtext__body {
    margin: 0;
    line-height: 1.6;
    color: var(--color-foreground, inherit);
  }

  #{{ section_id }} .dh-block-richtext__body > * + * { margin-top: 0.75em; }

  /* ────────────────────────────────────────────────
     IMAGE BLOCK
  ─────────────────────────────────────────────── */
  #{{ section_id }} .dh-block-image__heading {
    margin: 0 0 0.75rem;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-foreground, inherit);
  }

  #{{ section_id }} .dh-block-image__img-wrap {
    display: block;
    overflow: hidden;
    border-radius: var(--media-radius, 0px);
  }

  #{{ section_id }} .dh-block-image__img-wrap img {
    display: block;
    width: 100%;
    height: auto;
  }

  #{{ section_id }} .dh-block-image__text {
    margin: 0.75rem 0 0;
    line-height: 1.6;
    color: var(--color-foreground, inherit);
  }

  /* ────────────────────────────────────────────────
     GALLERY BLOCK — layout
  ─────────────────────────────────────────────── */
  #{{ section_id }} .dh-block-gallery { width: 100%; }

  /* Both orientations use flex; direction is set per-variant */
  #{{ section_id }} .dh-gallery__layout {
    display: flex;
    gap: 12px;
  }

  /* Bottom thumbnails: column layout (default) */
  #{{ section_id }} .dh-block-gallery[data-thumb-position="bottom"] .dh-gallery__layout {
    flex-direction: column;
  }

  /* Left thumbnails: row layout */
  #{{ section_id }} .dh-block-gallery[data-thumb-position="left"] .dh-gallery__layout {
    flex-direction: row;
    align-items: flex-start;
  }

  /* ── Featured image ── */
  #{{ section_id }} .dh-gallery__main { flex: 1; min-width: 0; }

  #{{ section_id }} .dh-gallery__main-btn {
    display: block;
    width: 100%;
    padding: 0;
    background: none;
    border: none;
    cursor: zoom-in;
  }

  #{{ section_id }} .dh-gallery__img-wrap {
    display: block;
    overflow: hidden;
    border-radius: var(--media-radius, 0px);
    background: var(--color-background-2, #f4f4f4);
  }

  /* Aspect ratio variants */
  #{{ section_id }} .dh-gallery__img-wrap[data-ratio="square"]    { aspect-ratio: 1 / 1; }
  #{{ section_id }} .dh-gallery__img-wrap[data-ratio="portrait"]  { aspect-ratio: 2 / 3; }
  #{{ section_id }} .dh-gallery__img-wrap[data-ratio="landscape"] { aspect-ratio: 4 / 3; }

  #{{ section_id }} .dh-gallery__main-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.2s;
  }

  /* Natural ratio: let image set its own height */
  #{{ section_id }} .dh-gallery__img-wrap[data-ratio="natural"] .dh-gallery__main-img {
    height: auto;
    object-fit: unset;
  }

  /* ── Thumbnails container ── */
  #{{ section_id }} .dh-gallery__thumbs {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
  }

  /* Horizontal strip (bottom) */
  #{{ section_id }} .dh-gallery__thumbs--bottom {
    flex-direction: row;
    align-items: center;
  }

  /* Vertical strip (left): fixed width, appears before main image */
  #{{ section_id }} .dh-gallery__thumbs--left {
    flex-direction: column;
    align-items: center;
    width: calc(var(--thumb-size, 80px) + 16px);
    order: -1;
  }

  /* Viewport: clips overflow */
  #{{ section_id }} .dh-gallery__thumbs-viewport {
    flex: 1;
    overflow: hidden;
    min-width: 0;
    min-height: 0;
  }

  #{{ section_id }} .dh-gallery__thumbs--left .dh-gallery__thumbs-viewport {
    max-height: 520px;
  }

  /* Track: the scrollable flex row/column */
  #{{ section_id }} .dh-gallery__thumbs-track {
    display: flex;
    gap: 6px;
  }

  #{{ section_id }} .dh-gallery__thumbs--bottom .dh-gallery__thumbs-track {
    flex-direction: row;
  }

  #{{ section_id }} .dh-gallery__thumbs--left .dh-gallery__thumbs-track {
    flex-direction: column;
  }

  /* Individual thumbnail */
  #{{ section_id }} .dh-gallery__thumb {
    flex-shrink: 0;
    display: block;
    width: var(--thumb-size, 80px);
    height: var(--thumb-size, 80px);
    padding: 0;
    border: 2px solid transparent;
    border-radius: var(--media-radius, 0px);
    overflow: hidden;
    cursor: pointer;
    background: none;
    transition: border-color 0.15s;
  }

  #{{ section_id }} .dh-gallery__thumb:hover,
  #{{ section_id }} .dh-gallery__thumb:focus-visible {
    border-color: var(--color-foreground, #000);
    outline: none;
  }

  #{{ section_id }} .dh-gallery__thumb.is-active {
    border-color: var(--color-foreground, #000);
  }

  #{{ section_id }} .dh-gallery__thumb img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  /* Scroll prev/next buttons */
  #{{ section_id }} .dh-gallery__scroll-btn {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    padding: 0;
    background: var(--color-background, #fff);
    border: 1px solid var(--color-border, #ddd);
    border-radius: 50%;
    cursor: pointer;
    color: var(--color-foreground, #000);
    transition: background 0.15s;
  }

  #{{ section_id }} .dh-gallery__scroll-btn:hover {
    background: var(--color-background-2, #f4f4f4);
  }

  /* ────────────────────────────────────────────────
     GALLERY BLOCK — lightbox
     (element is moved to <body> by JS so position:fixed
     is always relative to the viewport)
  ─────────────────────────────────────────────── */
  .dh-gallery__lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dh-gallery__lightbox[hidden] { display: none; }

  .dh-gallery__lb-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    cursor: zoom-out;
  }

  .dh-gallery__lb-frame {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    padding: 56px 72px;
    box-sizing: border-box;
    pointer-events: none;
  }

  .dh-gallery__lb-img-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: 100%;
    max-height: 100%;
    pointer-events: auto;
  }

  .dh-gallery__lb-img {
    display: block;
    max-width: 100%;
    max-height: calc(100dvh - 120px);
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: var(--media-radius, 0px);
  }

  /* Close button */
  .dh-gallery__lb-close {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    background: rgba(0, 0, 0, 0.55);
    border: none;
    border-radius: 50%;
    color: #fff;
    cursor: pointer;
    pointer-events: auto;
    transition: background 0.15s;
  }

  .dh-gallery__lb-close:hover { background: rgba(0, 0, 0, 0.8); }

  /* Prev / Next arrows */
  .dh-gallery__lb-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    padding: 0;
    background: rgba(0, 0, 0, 0.55);
    border: none;
    border-radius: 50%;
    color: #fff;
    cursor: pointer;
    pointer-events: auto;
    transition: background 0.15s;
  }

  .dh-gallery__lb-nav:hover { background: rgba(0, 0, 0, 0.8); }

  .dh-gallery__lb-nav--prev { left: 14px; }
  .dh-gallery__lb-nav--next { right: 14px; }

  /* ────────────────────────────────────────────────
     MOBILE OVERRIDES
  ─────────────────────────────────────────────── */
  @media (max-width: 749px) {
    /* Collapse two-column grid */
    #{{ section_id }} .dh-two-col__grid { grid-template-columns: 1fr; }
    #{{ section_id }} .dh-two-col__col--left  { order: 1; }
    #{{ section_id }} .dh-two-col__col--right { order: 2; }

    /* Left-position thumbnails collapse to horizontal bottom row on mobile */
    #{{ section_id }} .dh-block-gallery[data-thumb-position="left"] .dh-gallery__layout {
      flex-direction: column;
    }
    #{{ section_id }} .dh-gallery__thumbs--left {
      order: 0;
      width: 100%;
      flex-direction: row;
    }
    #{{ section_id }} .dh-gallery__thumbs--left .dh-gallery__thumbs-viewport {
      max-height: none;
    }
    #{{ section_id }} .dh-gallery__thumbs--left .dh-gallery__thumbs-track {
      flex-direction: row;
    }

    /* Compact lightbox padding on small screens */
    .dh-gallery__lb-frame { padding: 56px 14px 14px; }
    .dh-gallery__lb-nav   { width: 40px; height: 40px; }
  }
</style>

<section id="{{ section_id }}" class="dh-two-col color-{{ section.settings.color_scheme | default: 'background-1' }}">
  <div class="dh-two-col__container">
    <div class="dh-two-col__inner">

      {%- comment -%} ── SPANNING BLOCKS: ABOVE ── {%- endcomment -%}
      {%- assign has_above = false -%}
      {%- for block in section.blocks -%}
        {%- if block.settings.column == 'both' and block.settings.span_placement != 'below' -%}
          {%- assign has_above = true -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if has_above -%}
        <div class="dh-two-col__span dh-two-col__span--above">
          {%- for block in section.blocks -%}
            {%- if block.settings.column == 'both' and block.settings.span_placement != 'below' -%}
              {%- render 'dh-two-col-block', block: block, section_id: section_id -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} ── TWO-COLUMN GRID ── {%- endcomment -%}
      {%- if has_col_blocks -%}
        <div class="dh-two-col__grid">

          <div class="dh-two-col__col dh-two-col__col--left">
            {%- for block in section.blocks -%}
              {%- if block.settings.column == 'left' or block.settings.column == blank -%}
                {%- render 'dh-two-col-block', block: block, section_id: section_id -%}
              {%- endif -%}
            {%- endfor -%}
          </div>

          <div class="dh-two-col__col dh-two-col__col--right">
            {%- for block in section.blocks -%}
              {%- if block.settings.column == 'right' -%}
                {%- render 'dh-two-col-block', block: block, section_id: section_id -%}
              {%- endif -%}
            {%- endfor -%}
          </div>

        </div>
      {%- endif -%}

      {%- comment -%} ── SPANNING BLOCKS: BELOW ── {%- endcomment -%}
      {%- assign has_below = false -%}
      {%- for block in section.blocks -%}
        {%- if block.settings.column == 'both' and block.settings.span_placement == 'below' -%}
          {%- assign has_below = true -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if has_below -%}
        <div class="dh-two-col__span dh-two-col__span--below">
          {%- for block in section.blocks -%}
            {%- if block.settings.column == 'both' and block.settings.span_placement == 'below' -%}
              {%- render 'dh-two-col-block', block: block, section_id: section_id -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

<script>
(function () {
  'use strict';

  /* ─────────────────────────────────────────────────────────────
     DHGallery
     One instance per gallery block. Handles:
       - Thumbnail click → update featured image
       - Thumbnail overflow → show/hide prev/next scroll buttons
       - Featured image click → open lightbox
       - Lightbox prev/next/close + keyboard (Esc, ←, →)
     The lightbox element is moved to <body> on init so that
     position:fixed is always relative to the viewport, regardless
     of any CSS transforms on ancestor elements.
  ───────────────────────────────────────────────────────────── */
  class DHGallery {
    constructor(el) {
      this.el        = el;
      this.id        = el.dataset.gallery;
      this.currIdx   = 0;
      this.lbOpen    = false;

      /* Load image list from embedded JSON */
      const dataEl   = document.getElementById(this.id + '-data');
      this.images    = dataEl ? JSON.parse(dataEl.textContent).images : [];

      /* DOM refs */
      this.mainImg   = el.querySelector('[data-gallery-main-img]');
      this.openBtn   = el.querySelector('[data-gallery-open]');
      this.viewport  = el.querySelector('[data-gallery-thumbs-viewport]');
      this.track     = el.querySelector('[data-gallery-thumbs-track]');
      this.thumbs    = Array.from(el.querySelectorAll('[data-gallery-thumb]'));
      this.scrollBtns = Array.from(el.querySelectorAll('[data-gallery-scroll]'));

      /* Move lightbox to <body> */
      const lbEl = el.querySelector('[data-gallery-lightbox]');
      if (lbEl) {
        this.lb    = lbEl;
        this.lbImg = lbEl.querySelector('[data-gallery-lb-img]');
        document.body.appendChild(lbEl);
        /* Hide nav arrows when there is only one image */
        if (this.images.length <= 1) {
          lbEl.querySelectorAll('[data-gallery-lb-prev],[data-gallery-lb-next]')
              .forEach(b => { b.hidden = true; });
        }
      }

      this._bind();
      this._checkOverflow();

      /* Re-check after thumbnail images load */
      if (this.track) {
        Array.from(this.track.querySelectorAll('img')).forEach(img => {
          if (!img.complete) img.addEventListener('load', () => this._checkOverflow());
        });
      }

      /* Re-check on resize */
      if (window.ResizeObserver) {
        new ResizeObserver(() => this._checkOverflow()).observe(this.el);
      } else {
        window.addEventListener('resize', () => this._checkOverflow());
      }
    }

    _bind() {
      /* Thumbnail clicks */
      this.thumbs.forEach(btn => {
        btn.addEventListener('click', () => this.goTo(parseInt(btn.dataset.galleryThumb, 10)));
      });

      /* Open lightbox */
      if (this.openBtn) {
        this.openBtn.addEventListener('click', () => this._openLb(this.currIdx));
      }

      /* Thumb strip scroll buttons */
      this.scrollBtns.forEach(btn => {
        btn.addEventListener('click', () => this._scrollStrip(parseInt(btn.dataset.galleryScroll, 10)));
      });

      /* Lightbox controls */
      if (this.lb) {
        this.lb.querySelectorAll('[data-gallery-lb-close]').forEach(b => {
          b.addEventListener('click', () => this._closeLb());
        });
        const prev = this.lb.querySelector('[data-gallery-lb-prev]');
        const next = this.lb.querySelector('[data-gallery-lb-next]');
        if (prev) prev.addEventListener('click', () => this._lbNav(-1));
        if (next) next.addEventListener('click', () => this._lbNav(1));
      }

      /* Keyboard */
      document.addEventListener('keydown', e => {
        if (!this.lbOpen) return;
        if (e.key === 'Escape')     this._closeLb();
        if (e.key === 'ArrowLeft')  this._lbNav(-1);
        if (e.key === 'ArrowRight') this._lbNav(1);
      });
    }

    goTo(index) {
      if (index < 0 || index >= this.images.length) return;
      this.currIdx = index;

      /* Swap featured image */
      if (this.mainImg) {
        this.mainImg.style.opacity = '0.6';
        this.mainImg.src = this.images[index].src;
        this.mainImg.alt = this.images[index].alt || '';
        this.mainImg.onload = () => { this.mainImg.style.opacity = ''; };
      }

      /* Update active thumb */
      this.thumbs.forEach((b, i) => b.classList.toggle('is-active', i === index));

      /* Scroll active thumb into view */
      const active = this.thumbs[index];
      if (active && this.viewport) {
        const vert = this.el.dataset.thumbPosition === 'left';
        if (vert) {
          this.viewport.scrollTo({
            top: active.offsetTop - this.viewport.clientHeight / 2 + active.offsetHeight / 2,
            behavior: 'smooth'
          });
        } else {
          this.viewport.scrollTo({
            left: active.offsetLeft - this.viewport.clientWidth / 2 + active.offsetWidth / 2,
            behavior: 'smooth'
          });
        }
      }
    }

    _scrollStrip(dir) {
      if (!this.viewport) return;
      const vert   = this.el.dataset.thumbPosition === 'left';
      const size   = parseFloat(getComputedStyle(this.el).getPropertyValue('--thumb-size')) || 80;
      const amount = size * 2 + 12;
      if (vert) {
        this.viewport.scrollBy({ top: dir * amount, behavior: 'smooth' });
      } else {
        this.viewport.scrollBy({ left: dir * amount, behavior: 'smooth' });
      }
    }

    _checkOverflow() {
      if (!this.viewport || !this.track) return;
      const vert  = this.el.dataset.thumbPosition === 'left';
      const over  = vert
        ? this.track.scrollHeight > this.viewport.clientHeight + 4
        : this.track.scrollWidth  > this.viewport.clientWidth  + 4;
      this.scrollBtns.forEach(b => { b.hidden = !over; });
    }

    _openLb(index) {
      if (!this.lb) return;
      this.lbOpen = true;
      this._setLbImg(index);
      this.lb.hidden = false;
      document.body.style.overflow = 'hidden';
    }

    _closeLb() {
      if (!this.lb) return;
      this.lbOpen = false;
      this.lb.hidden = true;
      document.body.style.overflow = '';
    }

    _lbNav(dir) {
      const next = (this.currIdx + dir + this.images.length) % this.images.length;
      this.goTo(next);
      this._setLbImg(next);
    }

    _setLbImg(index) {
      if (!this.lbImg || !this.images[index]) return;
      this.lbImg.src = this.images[index].src;
      this.lbImg.alt = this.images[index].alt || '';
    }
  }

  /* Init all uninitialised gallery blocks in (optional) root */
  function initGalleries(root) {
    (root || document)
      .querySelectorAll('[data-gallery]:not([data-gallery-ready])')
      .forEach(el => { el.dataset.galleryReady = 'true'; new DHGallery(el); });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => initGalleries());
  } else {
    initGalleries();
  }

  /* Shopify theme editor: reinit on section/block load */
  document.addEventListener('shopify:section:load',  e => initGalleries(e.target));
  document.addEventListener('shopify:block:select',  e => initGalleries(e.target));

  /* Shopify theme editor: clean up orphaned lightboxes on section unload */
  document.addEventListener('shopify:section:unload', e => {
    const sid = e.detail && e.detail.sectionId;
    if (!sid) return;
    document.querySelectorAll(`.dh-gallery__lightbox[data-gallery-section="${sid}"]`)
            .forEach(lb => lb.remove());
    document.body.style.overflow = '';
  });

})();
</script>

{% schema %}
{
  "name": "DH Two Column",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
