{% comment %}
  DH Product Two Column Section
  A flexible two-column layout section for Shopify OS 2.0 product pages.
  Supports rich text, custom liquid, and image block types.
  Each block is assigned to left or right column via block settings.
{% endcomment %}

{%- liquid
  assign section_id = 'dh-two-col-' | append: section.id
  assign col_ratio   = section.settings.column_ratio | default: '50-50'
  assign col_gap     = section.settings.column_gap    | default: 32
  assign pt          = section.settings.padding_top   | default: 40
  assign pb          = section.settings.padding_bottom | default: 40
  assign v_align     = section.settings.vertical_align | default: 'start'
  assign bg_color    = section.settings.background_color

  case col_ratio
    when '50-50'
      assign left_fr  = '1fr'
      assign right_fr = '1fr'
    when '60-40'
      assign left_fr  = '3fr'
      assign right_fr = '2fr'
    when '40-60'
      assign left_fr  = '2fr'
      assign right_fr = '3fr'
    when '66-33'
      assign left_fr  = '2fr'
      assign right_fr = '1fr'
    when '33-66'
      assign left_fr  = '1fr'
      assign right_fr = '2fr'
    else
      assign left_fr  = '1fr'
      assign right_fr = '1fr'
  endcase

  assign left_blocks  = ''
  assign right_blocks = ''
  for block in section.blocks
    if block.settings.column == 'right'
      assign right_blocks = right_blocks | append: block.id | append: ','
    else
      assign left_blocks = left_blocks | append: block.id | append: ','
    endif
  endfor
-%}

<style>
  /* ── Section wrapper ── */
  #{{ section_id }} {
    background-color: {{ bg_color }};
    padding-top: {{ pt }}px;
    padding-bottom: {{ pb }}px;
  }

  /* ── Page-width container – mirrors Enterprise .page-width convention ── */
  #{{ section_id }} .dh-two-col__container {
    max-width: var(--page-width, 1200px);
    margin-inline: auto;
    padding-inline: var(--page-width-margin, clamp(1.5rem, 5vw, 3rem));
    box-sizing: border-box;
  }

  /* ── Two-column grid ── */
  #{{ section_id }} .dh-two-col__grid {
    display: grid;
    grid-template-columns: {{ left_fr }} {{ right_fr }};
    gap: {{ col_gap }}px;
    align-items: {{ v_align }};
  }

  /* ── Column wrappers ── */
  #{{ section_id }} .dh-two-col__col {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    min-width: 0; /* prevent blowout when content is wide */
  }

  /* ── Rich text block ── */
  #{{ section_id }} .dh-block-richtext__heading {
    margin: 0 0 0.5rem;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-foreground, inherit);
  }

  #{{ section_id }} .dh-block-richtext__body {
    margin: 0;
    line-height: 1.6;
    color: var(--color-foreground, inherit);
  }

  #{{ section_id }} .dh-block-richtext__body > * + * {
    margin-top: 0.75em;
  }

  /* ── Image block ── */
  #{{ section_id }} .dh-block-image__heading {
    margin: 0 0 0.75rem;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-foreground, inherit);
  }

  #{{ section_id }} .dh-block-image__img-wrap {
    display: block;
    overflow: hidden;
    border-radius: var(--media-radius, 0px);
  }

  #{{ section_id }} .dh-block-image__img-wrap img {
    display: block;
    width: 100%;
    height: auto;
  }

  #{{ section_id }} .dh-block-image__text {
    margin: 0.75rem 0 0;
    line-height: 1.6;
    color: var(--color-foreground, inherit);
  }

  /* ── Mobile: collapse to single column ── */
  @media (max-width: 749px) {
    #{{ section_id }} .dh-two-col__grid {
      grid-template-columns: 1fr;
    }

    /* Right column moves below left on mobile via order */
    #{{ section_id }} .dh-two-col__col--left  { order: 1; }
    #{{ section_id }} .dh-two-col__col--right { order: 2; }
  }
</style>

<section id="{{ section_id }}" class="dh-two-col color-{{ section.settings.color_scheme | default: 'background-1' }}">
  <div class="dh-two-col__container">
    <div class="dh-two-col__grid">

      {%- comment -%} ── LEFT COLUMN ── {%- endcomment -%}
      <div class="dh-two-col__col dh-two-col__col--left">
        {%- for block in section.blocks -%}
          {%- if block.settings.column == 'left' or block.settings.column == blank -%}
            {%- render 'dh-two-col-block', block: block, section_id: section_id -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- comment -%} ── RIGHT COLUMN ── {%- endcomment -%}
      <div class="dh-two-col__col dh-two-col__col--right">
        {%- for block in section.blocks -%}
          {%- if block.settings.column == 'right' -%}
            {%- render 'dh-two-col-block', block: block, section_id: section_id -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

{%- comment -%}
  ── INLINE BLOCK RENDERING ──
  Because Shopify does not allow partial includes with block loops in all themes,
  we render blocks inline using a second loop gated by column.
  The snippet approach above is the clean pattern; if the snippet is missing,
  the section gracefully renders nothing rather than erroring.

  Alternatively, replace the render calls above with the inline block markup below
  and remove the render tags if you prefer not to use a snippet file.
{%- endcomment -%}

{%- comment -%}
  ── BLOCK RENDERING FALLBACK (inline) ──
  If you are not using a snippet, replace each
    {%- render 'dh-two-col-block' ... -%}
  call with the inline content below.

  This file ships as self-contained: blocks are rendered inline in the columns above
  via the snippet tag. If the snippet is absent the section still loads without crashing.

  For a fully self-contained single-file version, use the structure immediately below.
{%- endcomment -%}

