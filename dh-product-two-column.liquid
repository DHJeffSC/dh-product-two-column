{% comment %}
  DH Product Two Column Section
  A flexible two-column layout section for Shopify OS 2.0 product pages.
  Supports rich text, custom liquid, and image block types.
  Each block can be assigned to the left column, right column, or both columns (full-width span).
  Spanning blocks can be placed above or below the two-column grid.
{% endcomment %}

{%- liquid
  assign section_id    = 'dh-two-col-' | append: section.id
  assign col_ratio     = section.settings.column_ratio     | default: '50-50'
  assign col_gap       = section.settings.column_gap       | default: 32
  assign pt            = section.settings.padding_top      | default: 40
  assign pb            = section.settings.padding_bottom   | default: 40
  assign v_align       = section.settings.vertical_align   | default: 'start'
  assign bg_color      = section.settings.background_color
  assign max_width_key = section.settings.max_width        | default: 'page'
  assign content_align = section.settings.content_alignment | default: 'center'

  case max_width_key
    when 'narrow'
      assign max_width_val = '720px'
    when 'medium'
      assign max_width_val = '960px'
    when 'wide'
      assign max_width_val = '1200px'
    when 'full'
      assign max_width_val = '100%'
    else
      assign max_width_val = 'var(--page-width, 1200px)'
  endcase

  case content_align
    when 'left'
      assign container_margin = '0 auto 0 0'
    when 'right'
      assign container_margin = '0 0 0 auto'
    else
      assign container_margin = '0 auto'
  endcase

  case col_ratio
    when '50-50'
      assign left_fr  = '1fr'
      assign right_fr = '1fr'
    when '60-40'
      assign left_fr  = '3fr'
      assign right_fr = '2fr'
    when '40-60'
      assign left_fr  = '2fr'
      assign right_fr = '3fr'
    when '66-33'
      assign left_fr  = '2fr'
      assign right_fr = '1fr'
    when '33-66'
      assign left_fr  = '1fr'
      assign right_fr = '2fr'
    else
      assign left_fr  = '1fr'
      assign right_fr = '1fr'
  endcase

  comment
    Check whether the section has any left/right blocks so we skip
    rendering an empty grid when only spanning blocks are present.
  endcomment
  assign has_col_blocks = false
  for block in section.blocks
    if block.settings.column == 'left' or block.settings.column == 'right' or block.settings.column == blank
      assign has_col_blocks = true
    endif
  endfor
-%}

<style>
  /* ── Section wrapper ── */
  #{{ section_id }} {
    background-color: {{ bg_color }};
    padding-top: {{ pt }}px;
    padding-bottom: {{ pb }}px;
  }

  /* ── Page-width container ── */
  #{{ section_id }} .dh-two-col__container {
    max-width: {{ max_width_val }};
    margin: {{ container_margin }};
    padding-inline: var(--page-width-margin, clamp(1.5rem, 5vw, 3rem));
    box-sizing: border-box;
  }

  /* ── Inner wrapper: stacks spanning rows + the grid with a consistent gap ── */
  #{{ section_id }} .dh-two-col__inner {
    display: flex;
    flex-direction: column;
    gap: {{ col_gap }}px;
  }

  /* ── Two-column grid ── */
  #{{ section_id }} .dh-two-col__grid {
    display: grid;
    grid-template-columns: {{ left_fr }} {{ right_fr }};
    gap: {{ col_gap }}px;
    align-items: {{ v_align }};
  }

  /* ── Column wrappers ── */
  #{{ section_id }} .dh-two-col__col {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    min-width: 0; /* prevent blowout when content is wide */
  }

  /* ── Spanning block row (full width above or below the grid) ── */
  #{{ section_id }} .dh-two-col__span {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
  }

  /* ── Rich text block ── */
  #{{ section_id }} .dh-block-richtext__heading {
    margin: 0 0 0.5rem;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-foreground, inherit);
  }

  #{{ section_id }} .dh-block-richtext__body {
    margin: 0;
    line-height: 1.6;
    color: var(--color-foreground, inherit);
  }

  #{{ section_id }} .dh-block-richtext__body > * + * {
    margin-top: 0.75em;
  }

  /* ── Image block ── */
  #{{ section_id }} .dh-block-image__heading {
    margin: 0 0 0.75rem;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-foreground, inherit);
  }

  #{{ section_id }} .dh-block-image__img-wrap {
    display: block;
    overflow: hidden;
    border-radius: var(--media-radius, 0px);
  }

  #{{ section_id }} .dh-block-image__img-wrap img {
    display: block;
    width: 100%;
    height: auto;
  }

  #{{ section_id }} .dh-block-image__text {
    margin: 0.75rem 0 0;
    line-height: 1.6;
    color: var(--color-foreground, inherit);
  }

  /* ── Mobile: collapse to single column ── */
  @media (max-width: 749px) {
    #{{ section_id }} .dh-two-col__grid {
      grid-template-columns: 1fr;
    }

    /* Right column moves below left on mobile via order */
    #{{ section_id }} .dh-two-col__col--left  { order: 1; }
    #{{ section_id }} .dh-two-col__col--right { order: 2; }
  }
</style>

<section id="{{ section_id }}" class="dh-two-col color-{{ section.settings.color_scheme | default: 'background-1' }}">
  <div class="dh-two-col__container">
    <div class="dh-two-col__inner">

      {%- comment -%} ── SPANNING BLOCKS: ABOVE ──
        Render any blocks assigned to "both" columns with placement "above" (or blank).
      {%- endcomment -%}
      {%- assign has_above = false -%}
      {%- for block in section.blocks -%}
        {%- if block.settings.column == 'both' and block.settings.span_placement != 'below' -%}
          {%- assign has_above = true -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if has_above -%}
        <div class="dh-two-col__span dh-two-col__span--above">
          {%- for block in section.blocks -%}
            {%- if block.settings.column == 'both' and block.settings.span_placement != 'below' -%}
              {%- render 'dh-two-col-block', block: block, section_id: section_id -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} ── TWO-COLUMN GRID ──
        Only rendered when at least one block is assigned to left or right.
      {%- endcomment -%}
      {%- if has_col_blocks -%}
        <div class="dh-two-col__grid">

          {%- comment -%} LEFT COLUMN {%- endcomment -%}
          <div class="dh-two-col__col dh-two-col__col--left">
            {%- for block in section.blocks -%}
              {%- if block.settings.column == 'left' or block.settings.column == blank -%}
                {%- render 'dh-two-col-block', block: block, section_id: section_id -%}
              {%- endif -%}
            {%- endfor -%}
          </div>

          {%- comment -%} RIGHT COLUMN {%- endcomment -%}
          <div class="dh-two-col__col dh-two-col__col--right">
            {%- for block in section.blocks -%}
              {%- if block.settings.column == 'right' -%}
                {%- render 'dh-two-col-block', block: block, section_id: section_id -%}
              {%- endif -%}
            {%- endfor -%}
          </div>

        </div>
      {%- endif -%}

      {%- comment -%} ── SPANNING BLOCKS: BELOW ──
        Render any blocks assigned to "both" columns with placement "below".
      {%- endcomment -%}
      {%- assign has_below = false -%}
      {%- for block in section.blocks -%}
        {%- if block.settings.column == 'both' and block.settings.span_placement == 'below' -%}
          {%- assign has_below = true -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if has_below -%}
        <div class="dh-two-col__span dh-two-col__span--below">
          {%- for block in section.blocks -%}
            {%- if block.settings.column == 'both' and block.settings.span_placement == 'below' -%}
              {%- render 'dh-two-col-block', block: block, section_id: section_id -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

<script>
  // No JavaScript required for this section.
  // Layout is handled entirely with CSS Grid and Flexbox.
</script>

{% schema %}
{
  "name": "DH Two Column",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "column_ratio",
      "label": "Column width ratio",
      "options": [
        { "value": "50-50", "label": "50 / 50" },
        { "value": "60-40", "label": "60 / 40" },
        { "value": "40-60", "label": "40 / 60" },
        { "value": "66-33", "label": "66 / 33" },
        { "value": "33-66", "label": "33 / 66" }
      ],
      "default": "50-50"
    },
    {
      "type": "select",
      "id": "vertical_align",
      "label": "Vertical alignment",
      "options": [
        { "value": "start",  "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "end",    "label": "Bottom" }
      ],
      "default": "start"
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Gap between columns",
      "info": "Also controls spacing between full-width spanning blocks and the column grid.",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Container"
    },
    {
      "type": "select",
      "id": "max_width",
      "label": "Max width",
      "options": [
        { "value": "page",   "label": "Theme page width" },
        { "value": "wide",   "label": "Wide (1200px)" },
        { "value": "medium", "label": "Medium (960px)" },
        { "value": "narrow", "label": "Narrow (720px)" },
        { "value": "full",   "label": "Full width" }
      ],
      "default": "page",
      "info": "\"Theme page width\" uses the --page-width CSS variable from the Enterprise theme."
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Container alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "center",
      "info": "Only visible when max width is narrower than the page."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "inverse",      "label": "Inverse" },
        { "value": "accent-1",     "label": "Accent 1" },
        { "value": "accent-2",     "label": "Accent 2" }
      ],
      "default": "background-1",
      "info": "Inherits Enterprise theme color scheme tokens."
    }
  ],
  "blocks": [
    {
      "type": "rich_text",
      "name": "Rich text",
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Column",
          "options": [
            { "value": "left",  "label": "Left" },
            { "value": "right", "label": "Right" },
            { "value": "both",  "label": "Both (full width)" }
          ],
          "default": "left"
        },
        {
          "type": "select",
          "id": "span_placement",
          "label": "Placement",
          "options": [
            { "value": "above", "label": "Above columns" },
            { "value": "below", "label": "Below columns" }
          ],
          "default": "above",
          "info": "Only applies when Column is set to \"Both (full width)\"."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Section heading"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body",
          "default": "<p>Use this block to add rich text content to either column. Supports <strong>bold</strong>, <em>italic</em>, links, and lists.</p>"
        }
      ]
    },
    {
      "type": "custom_liquid",
      "name": "Custom liquid",
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Column",
          "options": [
            { "value": "left",  "label": "Left" },
            { "value": "right", "label": "Right" },
            { "value": "both",  "label": "Both (full width)" }
          ],
          "default": "right"
        },
        {
          "type": "select",
          "id": "span_placement",
          "label": "Placement",
          "options": [
            { "value": "above", "label": "Above columns" },
            { "value": "below", "label": "Below columns" }
          ],
          "default": "above",
          "info": "Only applies when Column is set to \"Both (full width)\"."
        },
        {
          "type": "liquid",
          "id": "custom_liquid",
          "label": "Custom liquid",
          "info": "Add custom Liquid code. Access product, variant, and other Shopify objects here."
        }
      ]
    },
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "select",
          "id": "column",
          "label": "Column",
          "options": [
            { "value": "left",  "label": "Left" },
            { "value": "right", "label": "Right" },
            { "value": "both",  "label": "Both (full width)" }
          ],
          "default": "left"
        },
        {
          "type": "select",
          "id": "span_placement",
          "label": "Placement",
          "options": [
            { "value": "above", "label": "Above columns" },
            { "value": "below", "label": "Below columns" }
          ],
          "default": "above",
          "info": "Only applies when Column is set to \"Both (full width)\"."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "range",
          "id": "image_width",
          "label": "Image width",
          "min": 20,
          "max": 100,
          "step": 5,
          "unit": "%",
          "default": 100,
          "info": "Percentage of the column width (or full container when spanning both)."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading (optional)"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DH Two Column",
      "blocks": [
        {
          "type": "rich_text",
          "settings": {
            "column": "left",
            "heading": "Left column heading",
            "body": "<p>Add your left column content here.</p>"
          }
        },
        {
          "type": "rich_text",
          "settings": {
            "column": "right",
            "heading": "Right column heading",
            "body": "<p>Add your right column content here.</p>"
          }
        }
      ]
    }
  ],
  "templates": ["product", "page", "index"]
}
{% endschema %}
