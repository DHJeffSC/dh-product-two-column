{% comment %}
  Snippet: dh-two-col-block.liquid
  Renders a single block for the DH Two Column section.
  Called from dh-product-two-column.liquid

  Expected parameters:
    block       — the block object
    section_id  — the parent section's unique ID (for scoped CSS)
{% endcomment %}

{%- case block.type -%}

  {%- when 'rich_text' -%}
    {%- liquid
      assign heading_style = ''
      if block.settings.heading_size != 0
        assign heading_style = heading_style | append: 'font-size:' | append: block.settings.heading_size | append: 'px;'
      endif
      if block.settings.heading_color != blank
        assign heading_style = heading_style | append: 'color:' | append: block.settings.heading_color | append: ';'
      endif

      assign body_style = ''
      if block.settings.body_size != 0
        assign body_style = body_style | append: 'font-size:' | append: block.settings.body_size | append: 'px;'
      endif
      if block.settings.body_color != blank
        assign body_style = body_style | append: 'color:' | append: block.settings.body_color | append: ';'
      endif
    -%}
    <div class="dh-block-richtext" {{ block.shopify_attributes }}>
      {%- if block.settings.heading != blank -%}
        <h2 class="dh-block-richtext__heading"{% if heading_style != blank %} style="{{ heading_style }}"{% endif %}>{{ block.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if block.settings.body != blank -%}
        <div class="dh-block-richtext__body rte"{% if body_style != blank %} style="{{ body_style }}"{% endif %}>{{ block.settings.body }}</div>
      {%- endif -%}
    </div>

  {%- when 'custom_liquid' -%}
    <div class="dh-block-custom-liquid" {{ block.shopify_attributes }}>
      {{ block.settings.custom_liquid }}
    </div>

  {%- when 'image' -%}
    <div class="dh-block-image" {{ block.shopify_attributes }}>
      {%- if block.settings.heading != blank -%}
        <h3 class="dh-block-image__heading">{{ block.settings.heading | escape }}</h3>
      {%- endif -%}
      {%- if block.settings.image != blank -%}
        {%- assign img_width = block.settings.image_width | default: 100 -%}
        <span class="dh-block-image__img-wrap" style="max-width: {{ img_width }}%;">
          {{
            block.settings.image
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              widths: '400, 600, 800, 1000, 1200',
              sizes: '(max-width: 749px) 100vw, 50vw'
          }}
        </span>
      {%- endif -%}
      {%- if block.settings.text != blank -%}
        <div class="dh-block-image__text rte">{{ block.settings.text }}</div>
      {%- endif -%}
    </div>

{%- endcase -%}
